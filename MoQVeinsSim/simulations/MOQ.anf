t; AND name =~ &quot;track[car[0]/PCloud].objectsExpected&quot;) OR&#10;    (module =~ &quot;Highway.car[6].app[0]&quot; AND name =~ &quot;track[car[0]/PCloud].objectsLost&quot;) OR&#10;    (module =~ &quot;Highway.car[6].app[0]&quot; AND name =~ &quot;track[car[0]/BBox].objectsReceived&quot;) OR&#10;    (module =~ &quot;Highway.car[6].app[0]&quot; AND name =~ &quot;track[car[0]/BBox].objectsExpected&quot;) OR&#10;    (module =~ &quot;Highway.car[6].app[0]&quot; AND name =~ &quot;track[car[0]/BBox].objectsLost&quot;) OR&#10;    (module =~ &quot;Highway.car[7].app[0]&quot; AND name =~ &quot;track[car[0]/PCloud].objectsReceived&quot;) OR&#10;    (module =~ &quot;Highway.car[7].app[0]&quot; AND name =~ &quot;track[car[0]/PCloud].objectsExpected&quot;) OR&#10;    (module =~ &quot;Highway.car[7].app[0]&quot; AND name =~ &quot;track[car[0]/PCloud].objectsLost&quot;) OR&#10;    (module =~ &quot;Highway.car[7].app[0]&quot; AND name =~ &quot;track[car[0]/BBox].objectsReceived&quot;) OR&#10;    (module =~ &quot;Highway.car[7].app[0]&quot; AND name =~ &quot;track[car[0]/BBox].objectsExpected&quot;) OR&#10;    (module =~ &quot;Highway.car[7].app[0]&quot; AND name =~ &quot;track[car[0]/BBox].objectsLost&quot;)&#10;)"/>
