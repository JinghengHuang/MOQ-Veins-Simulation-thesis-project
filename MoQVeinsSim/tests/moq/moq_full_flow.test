%description:
Full MoQ handshake: publisher announces two tracks, subscriber subscribes
to both.  Verifies the complete relay handshake sequence in order:
  1. Publisher connects and announces BBox and PCloud tracks
  2. Relay registers both tracks and sends ANNOUNCE_OK for each
  3. Subscriber connects and subscribes to both tracks
  4. Relay finds each track, replies SUBSCRIBE_OK to subscriber,
     and forwards SUBSCRIBE_OK with track details to publisher
  5. Publisher sends track object data to relay, relay sends them to the respective subscribers 

Two-track scenario exercises that the relay's unordered_maps handle
multiple entries independently.

%file: test.ned

package moq_full_flow;
import inet.node.inet.StandardHost;
import inet.node.ethernet.Eth100M;
import inet.networklayer.configurator.ipv4.Ipv4NetworkConfigurator;

network TestMoqFullFlow
{
    submodules:
        configurator: Ipv4NetworkConfigurator;
        relay: StandardHost;
        publisher: StandardHost;
        subscriber: StandardHost;
    connections:
        publisher.ethg++  <--> Eth100M <--> relay.ethg++;
        subscriber.ethg++ <--> Eth100M <--> relay.ethg++;
}

%inifile: omnetpp.ini

[General]
network = TestMoqFullFlow
sim-time-limit = 5s
cmdenv-express-mode = false
cmdenv-event-banners = false
**.cmdenv-log-level = INFO
cmdenv-log-prefix = "%N: "

**.arp.retryCount = 0
**.arp.retryTimeout = 100ms

**.quic.initialMaxData = 1GB
**.quic.initialMaxStreamData = 1GB
**.quic.bundleAckForNonAckElicitingPackets = true

# --- Relay ---
*.relay.hasQuic = true
*.relay.quic.typename = "Quic"
*.relay.numApps = 1
*.relay.app[0].typename = "moqveinssim.applications.moq.MoqRelayApp"
*.relay.app[0].localAddress = ""
*.relay.app[0].localPort = 9001

# --- Publisher: two tracks respectively ---
*.publisher1.hasQuic = true
*.publisher1.quic.typename = "Quic"
*.publisher1.numApps = 1
*.publisher1.app[0].typename = "moqveinssim.applications.moq.MoqPublisherApp"
*.publisher1.app[0].localAddress = ""
*.publisher1.app[0].localPort = 9000
*.publisher1.app[0].connectAddress = "relay"
*.publisher1.app[0].connectPort = 9001
*.publisher1.app[0].connectTime = 0.2s
*.publisher1.app[0].tracks = [{trackName: "BBox", packetSize: 50B, sendInterval: 1s, priority: 0}]
*.publisher2.hasQuic = true
*.publisher2.quic.typename = "Quic"
*.publisher2.numApps = 1
*.publisher2.app[0].typename = "moqveinssim.applications.moq.MoqPublisherApp"
*.publisher2.app[0].localAddress = ""
*.publisher2.app[0].localPort = 9000
*.publisher2.app[0].connectAddress = "relay"
*.publisher2.app[0].connectPort = 9001
*.publisher2.app[0].connectTime = 0.2s
*.publisher2.app[0].tracks = [{trackName: "PCloud", packetSize: 300000B, sendInterval: 2s, priority: 1}]

# --- Subscriber: subscribe to both tracks ---
*.subscriber1.hasQuic = true
*.subscriber1.quic.typename = "Quic"
*.subscriber1.numApps = 1
*.subscriber1.app[0].typename = "moqveinssim.applications.moq.MoqSubscriberApp"
*.subscriber1.app[0].localAddress = ""
*.subscriber1.app[0].localPort = 9002
*.subscriber1.app[0].connectAddress = "relay"
*.subscriber1.app[0].connectPort = 9001
*.subscriber1.app[0].connectTime = 0.8s
*.subscriber1.app[0].tracks = [{trackNamespace: "publisher1", trackName: "BBox", startObjectId: 0, subscriberPriority: 0}]

*.subscriber2.hasQuic = true
*.subscriber2.quic.typename = "Quic"
*.subscriber2.numApps = 1
*.subscriber2.app[0].typename = "moqveinssim.applications.moq.MoqSubscriberApp"
*.subscriber2.app[0].localAddress = ""
*.subscriber2.app[0].localPort = 9002
*.subscriber2.app[0].connectAddress = "relay"
*.subscriber2.app[0].connectPort = 9001
*.subscriber2.app[0].connectTime = 0.8s
*.subscriber2.app[0].tracks = [{trackNamespace: "publisher2", trackName: "PCloud", startObjectId: 0, subscriberPriority: 0}]


%subst: /\x1B\[[0-9;]*m//

%# Both tracks registered by the relay
%contains-regex: stdout
.*Registered track publisher/BBox from publisher 0.*

%contains-regex: stdout
.*Registered track publisher/PCloud from publisher 0.*

%# Both subscriptions handled
%contains-regex: stdout
.*Subscriber subscriber subscribed to publisher/BBox.*

%contains-regex: stdout
.*Subscriber subscriber subscribed to publisher/PCloud.*

%# No SUBSCRIBE_ERROR should appear
%not-contains: stdout
SUBSCRIBE_ERROR
