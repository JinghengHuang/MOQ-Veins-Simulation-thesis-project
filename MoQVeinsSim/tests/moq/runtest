#!/bin/bash
# Run MoQ opp_test unit tests.
# Usage:  ./runtest [--debug|-d] [test-file(s)]   (defaults to all *.test in this directory)
set -e
cd "$(dirname "$0")"

# --- parse flags -----------------------------------------------------------
DEBUG=0
TEST_FILES_ARGS=()
for arg in "$@"; do
    case "$arg" in
        --debug|-d) DEBUG=1 ;;
        *) TEST_FILES_ARGS+=("$arg") ;;
    esac
done

# --- paths -----------------------------------------------------------------
OMNETPP=/home/jhuang/omnetpp/omnetpp-6.3.0
INET=/home/jhuang/thesiswork/inet-4.6.0
SIMU5G=/home/jhuang/thesiswork/simu5g-git
VEINS=/home/jhuang/thesiswork/veins-git
VEINS_INET=${VEINS}/subprojects/veins_inet
MOQSIM=/mnt/d/Work/Thesis/MoQVeinsSim

if [ "$DEBUG" -eq 1 ]; then
    OPP_RUN=${OMNETPP}/bin/opp_run_dbg
    MOQSIM_LIB="${MOQSIM}/out/clang-debug/src/MoQVeinsSim"
else
    OPP_RUN=${OMNETPP}/bin/opp_run
    MOQSIM_LIB="${MOQSIM}/out/clang-release/src/MoQVeinsSim"
fi

# Source the OMNeT++ environment (sets PATH, LD_LIBRARY_PATH, PYTHONPATH, etc.)
# shellcheck disable=SC1091
source "${OMNETPP}/setenv" > /dev/null 2>&1

# --- NED search paths ------------------------------------------------------
# Veins' package.ned declares "package org.car2x.veins" but the source tree
# uses a directory named "veins/" rather than "org/car2x/veins/".  OMNeT++ 6.3
# enforces that directory names match the package hierarchy, so adding the
# Veins src/ root directly causes a package-mismatch error.
#
# veins_compat/ is a one-level adapter: it contains a single symlink
#   org/car2x/veins -> <veins>/src/veins
# which gives OMNeT++ the expected directory path for "org.car2x.veins.*".
#
# With Veins resolvable we can include Simu5G's NED (needed by QuicNrCar.ned
# in our own src/) and use src/ directly instead of a filtered mirror.
VEINS_COMPAT="${MOQSIM}/tests/moq/veins_compat"
# veins_inet has no NED imports from Simu5G so it is excluded from the NED
# path (its .so is still loaded for symbol resolution).
NED_PATH=".:${INET}/src:${SIMU5G}/src:${VEINS_COMPAT}:${MOQSIM}/src"

# --- shared libraries to load ----------------------------------------------
# opp_run / opp_run_dbg resolve the library suffix (_dbg) automatically,
# so just pass the base name; the correct libveins-git[_dbg].so is picked up.
LOAD_LIBS=(
    "-l" "${INET}/src/INET"
    "-l" "${SIMU5G}/src/simu5g"
    "-l" "${VEINS}/src/veins-git"
    "-l" "${VEINS_INET}/src/veins_inet"
    "-l" "${MOQSIM_LIB}"
)

# Build one string of extra arguments for opp_run
EXTRA_ARGS="${LOAD_LIBS[*]} -n ${NED_PATH}"

# --- select test files -----------------------------------------------------
if [ "${#TEST_FILES_ARGS[@]}" -gt 0 ]; then
    TEST_FILES=("${TEST_FILES_ARGS[@]}")
else
    TEST_FILES=(*.test)
fi

MODE_LABEL=$([ "$DEBUG" -eq 1 ] && echo "debug" || echo "release")
echo "Running ${#TEST_FILES[@]} test(s) [${MODE_LABEL}]: ${TEST_FILES[*]}"
echo "---"

mkdir -p work
opp_test gen -w work "${TEST_FILES[@]}"
opp_test run -w work -p "${OPP_RUN}" "${TEST_FILES[@]}" -a "${EXTRA_ARGS}"
